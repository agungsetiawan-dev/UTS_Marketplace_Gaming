<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <TextView
        android:id="@+id/tv_title_terlaris"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Paling Laris"
        android:textColor="#38BDF8"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Koleksi gear terbaik minggu ini"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/tv_title_terlaris"
        app:layout_constraintTop_toBottomOf="@id/tv_title_terlaris" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTerlaris"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        tools:listitem="@layout/item_product_dashboard" />

</androidx.constraintlayout.widget.ConstraintLayout>